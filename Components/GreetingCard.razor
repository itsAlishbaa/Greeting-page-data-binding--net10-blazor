@page "/greeting"

<div class="greeting-container">
    <div class="card">
        <div class="card-header">
            <h2>Interactive Blazor Binding</h2>
            <p>Experience real-time data binding in .NET 10</p>
        </div>

        <div class="form-group">
            <label for="username">Enter Your Name</label>
            <div class="input-wrapper">
                <input id="username"
                       type="text"
                       @bind="UserName"
                       @bind:event="oninput"
                       placeholder="Type your full name..."
                       class="custom-input"
                       maxlength="30" />
                <span class="char-counter">@UserName.Length / 30</span>
            </div>
        </div>

        <hr class="divider" />

        <div class="display-section">
            
            <div class="display-box dynamic">
                <span class="badge dynamic-badge">Two-Way (Live Profiler)</span>
                
                @if (string.IsNullOrWhiteSpace(UserName))
                {
                    <div class="empty-state">
                        <div class="avatar anonymous">?</div>
                        <p class="placeholder-text">Waiting for user input to build profile...</p>
                    </div>
                }
                else
                {
                    <div class="profile-card-inner">
                        <div class="avatar active-avatar">@AvatarInitials</div>
                        
                        <div class="profile-info">
                            <h3>@TimeBasedGreeting, <span class="highlight">@UserName</span>!</h3>
                            <p class="sub-profile">Account Status: <span class="status-online">Active</span></p>
                        </div>
                    </div>
                }
            </div>

            <div class="display-box static">
                <span class="badge static-badge">One-Way (System Logs)</span>
                <div class="log-details">
                    <p><strong>Last Sync:</strong> <span class="status-text">@LastSyncTime</span></p>
                    <p><strong>App Engine:</strong> <span class="status-text">@EngineStatus</span></p>
                </div>
            </div>
        </div>

        <button class="btn-refresh" @onclick="RefreshSystemLogs">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z" />
                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
            </svg>
            Fetch Server Logs
        </button>
    </div>
</div>

@code {
    // Two-Way Binding Property
    private string _userName = string.Empty;
    private string UserName
    {
        get => _userName;
        set
        {
            _userName = value;
            UpdateDynamicProfile(); // Custom logic triggers instantly on typing
        }
    }

    // Dynamic UI states computed in Backend
    private string AvatarInitials { get; set; } = "?";
    private string TimeBasedGreeting { get; set; } = "Hello";

    // One-Way Binding Properties
    private string LastSyncTime { get; set; } = DateTime.Now.ToString("hh:mm:ss tt");
    private string EngineStatus { get; set; } = ".NET 10 Core Optimized";

    protected override void OnInitialized()
    {
        SetTimeBasedGreeting();
    }

    private void UpdateDynamicProfile()
    {
        // 1. Live Avatar Initials Generation
        if (!string.IsNullOrWhiteSpace(UserName))
        {
            var words = UserName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            AvatarInitials = words.Length > 1
                ? $"{words[0][0]}{words[1][0]}".ToUpper()
                : $"{words[0][0]}".ToUpper();
        }
        
        // 2. Refresh dynamic greeting based on current hour
        SetTimeBasedGreeting();
    }

    private void SetTimeBasedGreeting()
    {
        var hour = DateTime.Now.Hour;
        TimeBasedGreeting = hour < 12 ? "Good Morning" : hour < 17 ? "Good Afternoon" : "Good Evening";
    }

    // Explicit Method updating One-Way Data Binding
    private void RefreshSystemLogs()
    {
        string[] logs = { "Core Nominal", "Memory Cleared", "Garbage Collection Complete", "UI Thread Synced" };
        var random = new Random();
        
        LastSyncTime = DateTime.Now.ToString("hh:mm:ss tt");
        EngineStatus = logs[random.Next(logs.Length)];
    }
}
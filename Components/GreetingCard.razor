@page "/greeting"
@rendermode InteractiveServer
<div class="greeting-container">
    <div class="card">
        <div class="card-header">
            <h2>Greeting Dashboard</h2>
        </div>

        <div class="form-group">
            <label for="username">User Name</label>
            <input id="username"
                   type="text"
                   @bind="InputName"
                   @bind:event="oninput"
                   placeholder="Enter name..."
                   class="custom-input" />
        </div>

        <hr class="divider" />

        <div class="display-section">
            <div class="display-box dynamic">
                <span class="badge dynamic-badge">Live</span>
                <h3>Hello, @InputName</h3>
            </div>

            <div class="display-box static">
                <span class="badge static-badge">Static</span>
                <h3>Saved: @SavedGreeting</h3>
            </div>
        </div>

        <button class="btn-refresh" @onclick="SaveCurrentName">
            Save Changes
        </button>
    </div>
</div>

@code {
    private string InputName { get; set; } = string.Empty;
    private string SavedGreeting { get; set; } = string.Empty;

    private void SaveCurrentName()
    {
        SavedGreeting = InputName;
    }
}